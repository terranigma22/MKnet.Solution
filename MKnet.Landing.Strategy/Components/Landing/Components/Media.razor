@using MKnet.Landing.Strategy.Domain.Models

<div class="col-xl-3 col-lg-4 col-md-6 portfolio-item isotope-item filter-@Item.Category.ToLower()">
    <article class="portfolio-entry">
        @if (string.IsNullOrEmpty(Item.Link))
        {
            <figure class="entry-image">
                <img src="assets/img/portfolio/@Item.Image" class="img-fluid" alt="" loading="lazy">
                <div class="entry-overlay">
                    <div class="overlay-content">
                        <div class="entry-meta">@Item.Category.ToUpper()</div>
                        <h3 class="entry-title">@Item.Title</h3>
                    </div>
                </div>
            </figure>
        }
        else
        {
            <a href="@Item.Link" target="_blank" rel="noopener noreferrer">
                <figure class="entry-image">
                    <img src="assets/img/portfolio/@Item.Image" class="img-fluid" alt="" loading="lazy">
                    <div class="entry-overlay">
                        <div class="overlay-content">
                            <div class="entry-meta">@Item.Category.ToUpper()</div>
                            <h3 class="entry-title">@Item.Title</h3>
                        </div>
                    </div>
                </figure>
            </a>
        }
    </article>
</div>

@code {
    [Parameter, EditorRequired]
    public MediaDTO Item { get; set; }
}
